{
  "layer": "top",
  "position": "top",
  "margin-bottom": -10,
  "spacing": 0,
  "modules-left": [
    "niri/workspaces",
    "custom/uptime",
    "cpu",
    "custom/music-button",
    "custom/audio-visualizer"
  ],
  "modules-center": ["clock"],
  "modules-right": [
    "custom/update",
    "custom/pomodoro",
    "bluetooth",
    "network",
    "pulseaudio", 
    "backlight",
    "battery",
    "custom/power",
    "custom/wallpaper"
  ],
"niri/workspaces": {
  "format": "{icon}{name}",
  "format-icons": {
    "active": " â—ڈ ",
    "default": " â—‹ "
  }
},
  "custom/update": {
    "exec": "/home/user/dotfiles/config/waybar/scripts/system-update.sh",
    "return-type": "json",
    "format": "{}",
    "on-click": "/home/user/dotfiles/config/waybar/scripts/system-update.sh up",
    "interval": 30,
    "min-length": 1,
    "max-length": 1
  },
  "bluetooth": {
    "format": "َ°‚²",
    "format-on": "{icon}",
    "format-off": "{icon}", 
    "format-connected": "{icon}",
    "format-icons": {
      "on": "َ°‚¯",
      "off": "َ°‚²",
      "connected": "َ°‚±"
    },
    "on-click": "blueman-manager",
    "tooltip-format-connected": "{device_enumerate}"
  },
  "custom/wallpaper": {
    "format": "َ°¸‰",
    "tooltip": true,
    "tooltip-format": "Trocar Wallpaper",
    "on-click": "$HOME/dotfiles/bin/wallpaper-menu.sh",
    "on-click-right": "$HOME/dotfiles/bin/change-wall.sh"
  },
  "custom/music-button": {
    "format": "",
    "tooltip": true,
    "exec": "playerctl metadata --format '{{artist}} - {{title}}' 2>/dev/null || echo 'No music playing'",
    "interval": 2,
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-click-middle": "playerctl previous"
  },
  "custom/audio-visualizer": {
    "format": "â™ھ {}",
    "exec": "/home/user/dotfiles/config/waybar/scripts/audio-visualizer.sh",
    "interval": 1,
    "tooltip": true,
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-click-middle": "playerctl previous"
  },
  "clock": {
    "timezone": "Asia/Kolkata",
    "tooltip": false,
    "format": "{:%H:%M:%S  -  %A, %d}",
    "interval": 1
  },
  "network": {
    "format-wifi": "َ°¤¢",
    "format-ethernet": "َ°ˆ€ ",
    "format-disconnected": "َ°¤  ",
    "interval": 5,
    "tooltip-format": "{essid} ({signalStrength}%)",
    "on-click": "nmgui"
  },
  "cpu": {
    "interval": 1,
    "format": "  {icon0}{icon1}{icon2}{icon3} {usage:>2}%",
    "format-icons": ["â–پ", "â–‚", "â–ƒ", "â–„", "â–…", "â–†", "â–‡", "â–ˆ"],
    "on-click": "wezterm -e btop"
  },
  "memory": {
    "interval": 30,
    "format": "  {used:0.1f}G/{total:0.1f}G",
    "tooltip-format": "Memory"
  },
  "custom/uptime": {
    "format": "{}",
    "format-icon": [""], 
    "tooltip": false,
    "interval": 1600,
    "exec": "$HOME/config/waybar/scripts/uptime.sh"
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["َ±©ژ", "َ±©ڈ", "َ±©گ", "َ±©‘", "َ±©’", "َ±©“", "َ±©”"],
    "tooltip": false
  },
  "pulseaudio": {
    "format": "{icon} <b>{volume}%</b>",
    "format-bluetooth": "َ±،ڈ <b>{volume}%</b>",
    "format-bluetooth-muted": "َ°‌ں <b>Muted</b>",
    "format-muted": "َ°‌ں <b>Muted</b>",
    "format-icons": {
      "headphone": "َ°‹‹",
      "hands-free": "َ±،ڈ",
      "headset": "َ°‹ژ",
      "phone": "",
      "portable": "",
      "car": "َ°„‹",
      "default": ["َ°•؟", "َ°–€", "َ°•¾"]
    },
    "scroll-step": 5,
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pavucontrol",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%",
    "tooltip": true,
    "tooltip-format": "{desc}\nVolume: {volume}%"
  },
  "battery": {
    "interval": 2,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-full": "{icon}  {capacity}%",
    "format-charging": "َ°‚„  {capacity}%",
    "format-plugged": "َ°ڑ¥  {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"]
  },
  "custom/power" : {
    "format": "âڈ»",
    "tooltip": false,
    "on-click": "wlogout"
  },
  "custom/lock": {
    "tooltip": false,
    "on-click": "sh -c '(sleep 0s; hyprlock)' & disown",
    "format": ""
  },
  "custom/pomodoro": {
    "format": "{}",
    "return-type": "json",
    "exec": "/home/user/dotfiles/config/waybar/scripts/pomodoro.sh",
    "on-click": "/home/user/dotfiles/config/waybar/scripts/pomodoro.sh toggle",
    "interval": 1
  }
}
