{
  "layer": "top",
  "position": "top",
  "margin-bottom": -10,
  "spacing": 0,

  "modules-left": [
    "hyprland/workspaces",
    "cpu"
  ],
  "modules-center": ["clock"],
  "modules-right": [],

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "ᗧ",
      "default": "ᗣ"
    },
    "persistent-workspaces": {
      "*": 5
    },
    "sort-by-number": true,
    "on-click": "activate"
  },

  "clock": {
    "format": "{:%H:%M  %a, %d %b}",
    "interval": 60,
    "tooltip": false
  },

  "cpu": {
    "interval": 2,
    "format": "  {usage}%",
    "on-click": "kitty -e btop"
  }
}